{
  "openapi": "3.1.0",
  "info": {
    "title": "OpenAPI 3.1 type arrays",
    "version": "1.0.0"
  },
  "paths": {
    "/items": {
      "get": {
        "operationId": "listItems",
        "tags": ["items"],
        "responses": {
          "200": {
            "description": "Listing",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Item" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Item": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": ["string", "null"] },
          "count": { "type": ["null", "integer"] },
          "tags": { "type": ["array", "null"], "items": { "type": "string" } },
          "meta": { "type": ["object", "null"] },
          "passthrough": {}
        }
      }
    }
  }
}
