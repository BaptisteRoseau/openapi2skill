{
  "openapi": "3.0.0",
  "info": {
    "title": "Cyclic Refs",
    "version": "1.0.0"
  },
  "paths": {
    "/nodes/{id}": {
      "get": {
        "operationId": "getNode",
        "tags": ["nodes"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "A node",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Node" }
              }
            }
          }
        }
      }
    },
    "/invoices/{id}": {
      "get": {
        "operationId": "getInvoice",
        "tags": ["billing"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "An invoice",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Invoice" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Node": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "next": { "$ref": "#/components/schemas/Node" },
          "children": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Node" }
          }
        }
      },
      "Invoice": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "customer": { "$ref": "#/components/schemas/Customer" }
        }
      },
      "Customer": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "invoices": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Invoice" }
          }
        }
      }
    }
  }
}
